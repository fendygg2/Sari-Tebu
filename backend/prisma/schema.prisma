generator client {
    provider = "prisma-client"      // Required
    output   = "./generated"        // Required (letakkan generated/ relasi terhadap schema.prisma)

    importFileExtension = "ts"      // Setting importFileExtension = "ts" ensures the generated imports match what tsx expects
                                    // Berdasarkan `https://www.prisma.io/docs/orm/prisma-schema/overview/generators#field-reference`
}

datasource db {
    provider = "mysql"
}

model User {
    id                      String                  @id             
    email_address           String                  @unique         // ingat @index akan automatically buat index untuk kolom ini
    username                String              
    password_hash           Bytes                   @db.Blob
    created_at              DateTime                @default(now())
    updated_at              DateTime                @updatedAt

    auth_sessions           AuthSession[]
    password_reset_sessions PasswordResetSession[]
    carts                   Cart[]
    transactions            Transaction[]

    @@map("users")
}

model AuthSession {
    id                            String                       @id             
    user_id                       String                                       
    session_secret_hash           Bytes                        @db.Blob
    created_at                    DateTime                     @default(now())
    expires_at                    DateTime
    account_deletion_sessions     accountDeletionSession[]
    email_address_update_sessions emailAddresssUpdateSession[]
    password_update_sessions      passwordUpdateSession[]
    user                          User                         @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@map("auth_sessions")
    @@index([user_id])
}

model PasswordResetSession {
    id                  String   @id      
    user_id             String            
    session_secret_hash Bytes    @db.Blob
    email_code_hash     Bytes    @db.Blob
    is_email_verified   Boolean
    created_at          DateTime @default(now())
    expires_at          DateTime
    user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@map("password_reset_sessions")
    @@index([user_id])
}

model accountDeletionSession {
    id                  String      @id      
    auth_session_id     String                
    session_secret_hash Bytes       @db.Blob
    is_email_verified   Boolean
    created_at          DateTime    @default(now())
    expires_at          DateTime
    authSession         AuthSession @relation(fields: [auth_session_id], references: [id], onDelete: Cascade)

    @@map("account_deletion_sessions")
    @@index([auth_session_id])
}

model emailAddresssUpdateSession {
    id                  String      @id      
    auth_session_id     String               
    session_secret_hash Bytes       @db.Blob
    is_email_verified   Boolean
    new_email_address   String
    email_code_hash     Bytes
    created_at          DateTime    @default(now())
    expires_at          DateTime
    authSession         AuthSession @relation(fields: [auth_session_id], references: [id], onDelete: Cascade)

    @@map("email_address_update_sessions")
    @@index([auth_session_id])
}

model passwordUpdateSession {
    id                  String      @id      
    auth_session_id     String                
    session_secret_hash Bytes       @db.Blob
    is_email_verified   Boolean
    created_at          DateTime    @default(now())
    expires_at          DateTime
    authSession         AuthSession @relation(fields: [auth_session_id], references: [id], onDelete: Cascade)

    @@map("password_update_sessions")
    @@index([auth_session_id])
}

model SignupSession {
    id                  String   @id      
    session_secret_hash Bytes    @db.Blob
    email_address       String
    email_code_hash     String
    is_email_verified   Boolean
    created_at          DateTime @default(now())
    expires_at          DateTime

    @@map("signup_sessions")
}

model Product {
    id                String            @id 
    name              String            @unique
    price             Int
    stock             Int
    created_at        DateTime          @default(now())
    updated_at        DateTime          @updatedAt
    cart_items        CartItem[]
    transaction_items TransactionItem[]

    @@map("products")
}

model Cart {
    id         String     @id             
    user_id    String                     
    created_at DateTime   @default(now())
    updated_at DateTime   @updatedAt
    items      CartItem[]
    user       User       @relation(fields: [user_id], references: [id])

    @@map("carts")
    @@index([user_id])
}

model CartItem {
    cart_id    String  
    product_id String  
    quantity   Int

    cart       Cart    @relation(fields: [cart_id], references: [id], onDelete: Cascade)
    product    Product @relation(fields: [product_id], references: [id])

    @@id([cart_id, product_id])
    @@map("cart_items")
}

model Transaction {
    id         String            @id 
    user_id    String            
    total      Int
    created_at DateTime          @default(now())
    updated_at DateTime          @updatedAt
    items      TransactionItem[]
    user       User              @relation(fields: [user_id], references: [id])

    @@index([user_id])
    @@map("transactions")
}

model TransactionItem {
    transaction_id String      
    product_id     String      
    quantity       Int
    price_at_time  Int
    product        Product     @relation(fields: [product_id], references: [id])
    transaction    Transaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)

    @@id([transaction_id, product_id])
    @@map("transaction_items")
}
