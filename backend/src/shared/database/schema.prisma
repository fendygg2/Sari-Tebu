generator client {
    provider = "prisma-client"      // Required
    output   = "./generated"        // Required (letakkan generated/ relasi terhadap schema.prisma)

    importFileExtension = "ts"      // Setting importFileExtension = "ts" ensures the generated imports match what tsx expects
                                    // Berdasarkan `https://www.prisma.io/docs/orm/prisma-schema/overview/generators#field-reference`
}

datasource db {
    provider = "mysql"
}

model User {
    id            String        @id @db.VarChar(32)
    email_address String        @unique
    username      String
    password_hash String        @db.VarChar(255)
    created_at    DateTime      @default(now())
    updated_at    DateTime      @updatedAt
    
    carts                   Cart[]
    transactions            Transaction[]
    auth_sessions           AuthSession[]
    // password_reset_sessions PasswordResetSession[]

    @@map("users")
}

model AuthSession {
    id              String   @id @db.VarChar(32)
    user_id         String   @db.VarChar(32)
    refresh_token   String   @db.VarChar(64)
    created_at      DateTime @default(now())
    expires_at      DateTime
    user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

    // email_address_update_sessions   EmailAddressUpdateSession[]
    // password_update_sessions        PasswordUpdateSession[]
    // account_deletion_sessions       AccountDeletionSession[]

    @@map("auth_sessions")
}

